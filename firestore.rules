rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 1. Global Safety Net (First Rule Block)
    match /{document=**} {
      allow read, write: if false;
    }

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function hasVerifiedEmail() {
      return isAuthenticated() && 
             request.auth.token.email is string &&
             request.auth.token.email_verified == true;
    }

    function hasActiveUserRole(role) {
      return hasVerifiedEmail() &&
             exists(/databases/$(database)/documents/userRoles/$(request.auth.token.email)) &&
             get(/databases/$(database)/documents/userRoles/$(request.auth.token.email)).data.email == request.auth.token.email &&
             get(/databases/$(database)/documents/userRoles/$(request.auth.token.email)).data.status == 'active' &&
             get(/databases/$(database)/documents/userRoles/$(request.auth.token.email)).data.role == role;
    }

    function hasActiveCompanyRole(companyId) {
      return hasVerifiedEmail() &&
             companyId is string &&
             exists(/databases/$(database)/documents/userRoles/$(request.auth.token.email)) &&
             get(/databases/$(database)/documents/userRoles/$(request.auth.token.email)).data.email == request.auth.token.email &&
             get(/databases/$(database)/documents/userRoles/$(request.auth.token.email)).data.status == 'active' &&
             get(/databases/$(database)/documents/userRoles/$(request.auth.token.email)).data.companyId == companyId &&
             get(/databases/$(database)/documents/userRoles/$(request.auth.token.email)).data.role in ['company_admin', 'company_staff'];
    }

    function isAdmin() {
      return hasVerifiedEmail() &&
        (
          request.auth.token.email in ["israel.quinde@gmail.com"] ||
          hasActiveUserRole('super_admin')
        );
    }

    function isCompanyMember(companyId) {
      return hasVerifiedEmail() &&
             companyId is string &&
             exists(/databases/$(database)/documents/companies/$(companyId)) &&
             get(/databases/$(database)/documents/companies/$(companyId)).data.status == 'active' &&
             hasActiveCompanyRole(companyId);
    }

    function isActiveCompany(companyId) {
      return companyId is string &&
             exists(/databases/$(database)/documents/companies/$(companyId)) &&
             get(/databases/$(database)/documents/companies/$(companyId)).data.status == 'active';
    }

    function isOwnCustomerRecord(data) {
      return isAuthenticated() &&
             data.authUid is string &&
             data.authUid == request.auth.uid;
    }

    function isOwnOrderCustomer(data) {
      return isAuthenticated() &&
             data.customerId is string &&
             exists(/databases/$(database)/documents/customers/$(data.customerId)) &&
             get(/databases/$(database)/documents/customers/$(data.customerId)).data.authUid == request.auth.uid &&
             get(/databases/$(database)/documents/customers/$(data.customerId)).data.companyId == data.companyId;
    }

    function hasRequiredFields(data, fields) {
      return data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(data, fields) {
      return data.keys().hasOnly(fields);
    }

    // Product Validator
    function isValidProduct(data) {
      return hasRequiredFields(data, ['name', 'price', 'image', 'category', 'createdAt']) &&
             hasOnlyAllowedFields(data, ['id', 'name', 'description', 'price', 'costPrice', 'stock', 'minStock', 'image', 'images', 'category', 'status', 'sku', 'createdAt', 'updatedAt', 'companyId']) &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             (!('description' in data) || data.description == null || (data.description is string && data.description.size() <= 1000)) &&
             data.price is number && data.price > 0 &&
             (!('costPrice' in data) || data.costPrice == null || data.costPrice is number) &&
             (!('stock' in data) || data.stock == null || (data.stock is number && data.stock >= 0)) &&
             (!('minStock' in data) || data.minStock == null || (data.minStock is number && data.minStock >= 0)) &&
             (!('status' in data) || data.status == null || (data.status in ['active', 'inactive'])) &&
             (!('sku' in data) || data.sku == null || (data.sku is string && data.sku.size() <= 50)) &&
             data.image is string && (data.image == '' || data.image.matches("^https://.*") || data.image.matches("^http://.*") || data.image.matches("^data:image/.*")) &&
             (!('images' in data) || data.images == null || (data.images is list && data.images.size() <= 10)) &&
             data.category is string && data.category.size() > 0 && data.category.size() <= 100 &&
             (!('companyId' in data) || data.companyId == null || (data.companyId is string && data.companyId.size() <= 100));
    }

    // Settings Validator
    function isValidSettings(data) {
      return hasRequiredFields(data, ['storeName', 'heroTitle', 'heroSubtitle', 'heroImage', 'footerText']) &&
             hasOnlyAllowedFields(data, ['storeName', 'heroTitle', 'heroSubtitle', 'heroBadgeText', 'productSectionTitle', 'productSectionDescription', 'heroImage', 'logoImage', 'footerText', 'socialLinks', 'heroBgType', 'heroBgColor', 'heroTextColor', 'stockAlertPercentage', 'supportPhone', 'supportEmail', 'whatsappNumber']) &&
             data.storeName is string && data.storeName.size() > 0 && data.storeName.size() <= 100 &&
             data.heroTitle is string && data.heroTitle.size() > 0 && data.heroTitle.size() <= 200 &&
             data.heroSubtitle is string && data.heroSubtitle.size() > 0 && data.heroSubtitle.size() <= 1000 &&
             (!('heroBadgeText' in data) || data.heroBadgeText == null || (data.heroBadgeText is string && data.heroBadgeText.size() <= 120)) &&
             (!('productSectionTitle' in data) || data.productSectionTitle == null || (data.productSectionTitle is string && data.productSectionTitle.size() > 0 && data.productSectionTitle.size() <= 120)) &&
             (!('productSectionDescription' in data) || data.productSectionDescription == null || (data.productSectionDescription is string && data.productSectionDescription.size() > 0 && data.productSectionDescription.size() <= 500)) &&
             data.heroImage is string && (data.heroImage.matches("^https://.*") || data.heroImage.matches("^http://.*") || data.heroImage.matches("^data:image/.*")) &&
             (!('logoImage' in data) || data.logoImage == null || data.logoImage == '' || (data.logoImage is string && (data.logoImage.matches("^https://.*") || data.logoImage.matches("^http://.*")))) &&
             data.footerText is string && data.footerText.size() > 0 && data.footerText.size() <= 500 &&
             (!('socialLinks' in data) || data.socialLinks == null || data.socialLinks is map) &&
             (!('heroBgType' in data) || data.heroBgType == null || (data.heroBgType is string)) &&
             (!('heroBgColor' in data) || data.heroBgColor == null || (data.heroBgColor is string)) &&
             (!('heroTextColor' in data) || data.heroTextColor == null || (data.heroTextColor is string)) &&
             (!('stockAlertPercentage' in data) || data.stockAlertPercentage == null || (data.stockAlertPercentage is number)) &&
             (!('supportPhone' in data) || data.supportPhone == null || (data.supportPhone is string)) &&
             (!('supportEmail' in data) || data.supportEmail == null || (data.supportEmail is string)) &&
             (!('whatsappNumber' in data) || data.whatsappNumber == null || (data.whatsappNumber is string));
    }

    // Customer Validator
    function isValidCustomer(data) {
      return hasRequiredFields(data, ['name']) &&
             hasOnlyAllowedFields(data, ['id', 'authUid', 'name', 'phone', 'address', 'logisticsLocationId', 'city', 'province', 'totalSpent', 'currentDebt', 'createdAt', 'lastPurchase', 'email', 'creditLimit', 'companyId', 'status', 'cedula']) &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             (!('authUid' in data) || data.authUid == null || (data.authUid is string && data.authUid.size() <= 128)) &&
             (!('phone' in data) || data.phone == null || (data.phone is string && data.phone.size() <= 30)) &&
             (!('address' in data) || data.address == null || (data.address is string && data.address.size() <= 200)) &&
             (!('logisticsLocationId' in data) || data.logisticsLocationId == null || (data.logisticsLocationId is string && data.logisticsLocationId.size() <= 100)) &&
             (!('city' in data) || data.city == null || (data.city is string && data.city.size() <= 100)) &&
             (!('province' in data) || data.province == null || (data.province is string && data.province.size() <= 100)) &&
             (!('totalSpent' in data) || data.totalSpent == null || (data.totalSpent is number && data.totalSpent >= 0)) &&
             (!('currentDebt' in data) || data.currentDebt == null || (data.currentDebt is number && data.currentDebt >= 0)) &&
             (!('email' in data) || data.email == null || (data.email is string && data.email.size() <= 100)) &&
             (!('creditLimit' in data) || data.creditLimit == null || (data.creditLimit is number)) &&
             (!('companyId' in data) || data.companyId == null || (data.companyId is string && data.companyId.size() <= 100)) &&
             (!('status' in data) || data.status == null || (data.status is string && data.status.size() <= 30)) &&
             (!('cedula' in data) || data.cedula == null || (data.cedula is string && data.cedula.size() <= 30));
    }

    // Order Validator
    function isValidOrder(data) {
      return hasRequiredFields(data, ['id', 'items', 'subtotal', 'total', 'status', 'dispatchStatus', 'paymentMethod', 'paymentStatus', 'amountPaid', 'customerName', 'createdAt']) &&
             hasOnlyAllowedFields(data, ['id', 'items', 'subtotal', 'total', 'shippingCost', 'shippingLocationCode', 'shippingLocationName', 'shippingProvince', 'shippingCanton', 'status', 'dispatchStatus', 'paymentMethod', 'paymentStatus', 'amountPaid', 'customerId', 'customerName', 'customerPhone', 'customerCedula', 'createdAt', 'notes', 'companyId', 'discount', 'tax']) &&
             data.id is string && data.id.size() > 0 && data.id.size() <= 100 &&
             data.items is list && data.items.size() > 0 && data.items.size() <= 50 &&
             data.subtotal is number && data.subtotal >= 0 &&
             data.total is number && data.total >= 0 &&
             data.status is string && data.status in ['pending', 'completed', 'cancelled', 'dispatched'] &&
             data.dispatchStatus is string && data.dispatchStatus in ['pending', 'shipped', 'delivered', 'dispatched'] &&
             data.paymentMethod is string && data.paymentMethod in ['cash', 'transfer', 'credit', 'card'] &&
             data.paymentStatus is string && data.paymentStatus in ['paid', 'unpaid', 'partially_paid'] &&
             data.amountPaid is number && data.amountPaid >= 0 &&
             data.customerName is string && data.customerName.size() > 0 && data.customerName.size() <= 100 &&
             (!('shippingCost' in data) || data.shippingCost == null || (data.shippingCost is number && data.shippingCost >= 0)) &&
             (!('shippingLocationCode' in data) || data.shippingLocationCode == null || (data.shippingLocationCode is string && data.shippingLocationCode.size() <= 100)) &&
             (!('shippingLocationName' in data) || data.shippingLocationName == null || (data.shippingLocationName is string && data.shippingLocationName.size() <= 250)) &&
             (!('shippingProvince' in data) || data.shippingProvince == null || (data.shippingProvince is string && data.shippingProvince.size() <= 100)) &&
             (!('shippingCanton' in data) || data.shippingCanton == null || (data.shippingCanton is string && data.shippingCanton.size() <= 100)) &&
             (!('customerPhone' in data) || data.customerPhone == null || (data.customerPhone is string && data.customerPhone.size() <= 30)) &&
             (!('customerCedula' in data) || data.customerCedula == null || (data.customerCedula is string && data.customerCedula.size() <= 30)) &&
             (!('notes' in data) || data.notes == null || (data.notes is string && data.notes.size() <= 1000)) &&
             (!('companyId' in data) || data.companyId == null || (data.companyId is string && data.companyId.size() <= 100)) &&
             (!('discount' in data) || data.discount == null || (data.discount is number)) &&
             (!('tax' in data) || data.tax == null || (data.tax is number));
    }

    function isValidOrderWorkflowEdit() {
      return isValidOrder(request.resource.data) &&
             resource.data.companyId == request.resource.data.companyId &&
             request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'dispatchStatus', 'paymentMethod', 'paymentStatus', 'amountPaid']);
    }

    // Payment Transaction Validator
    function isValidTransaction(data) {
      return hasRequiredFields(data, ['id', 'customerId', 'customerName', 'amount', 'paymentMethod', 'date']) &&
             hasOnlyAllowedFields(data, ['id', 'orderId', 'orderNumber', 'customerId', 'customerName', 'amount', 'paymentMethod', 'referenceNumber', 'bankName', 'date', 'notes', 'companyId']) &&
             data.id is string && data.id.size() > 0 &&
             data.customerId is string &&
             data.customerName is string &&
             data.amount is number && data.amount > 0 &&
             data.paymentMethod is string &&
             (!('companyId' in data) || data.companyId == null || (data.companyId is string && data.companyId.size() <= 100));
    }

    // Purchase Validator
    function isValidPurchase(data) {
      return hasRequiredFields(data, ['id', 'lot', 'date', 'items', 'total']) &&
             hasOnlyAllowedFields(data, ['id', 'lot', 'date', 'items', 'total', 'historical', 'supplier', 'notes', 'createdAt', 'companyId']) &&
             data.id is string && data.id.size() > 0 && data.id.size() <= 100 &&
             data.lot is string && data.lot.size() > 0 && data.lot.size() <= 100 &&
             data.items is list && data.items.size() > 0 && data.items.size() <= 50 &&
             data.total is number && data.total > 0 &&
             (!('historical' in data) || data.historical == null || data.historical is bool) &&
             (!('supplier' in data) || data.supplier == null || (data.supplier is string && data.supplier.size() <= 150)) &&
             (!('notes' in data) || data.notes == null || (data.notes is string && data.notes.size() <= 1000)) &&
             (!('companyId' in data) || data.companyId == null || (data.companyId is string && data.companyId.size() <= 100));
    }

    // Company Validator
    function isValidCompany(data) {
      return hasRequiredFields(data, ['name', 'storeName', 'status', 'createdAt']) &&
             hasOnlyAllowedFields(data, ['id', 'name', 'ownerEmail', 'collaboratorEmails', 'storeName', 'status', 'description', 'phone', 'whatsapp', 'email', 'createdAt']) &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             (!('ownerEmail' in data) || data.ownerEmail == null || (data.ownerEmail is string && data.ownerEmail.size() <= 100)) &&
             (!('collaboratorEmails' in data) || data.collaboratorEmails == null || (data.collaboratorEmails is list && data.collaboratorEmails.size() <= 20)) &&
             data.storeName is string && data.storeName.size() > 0 && data.storeName.size() <= 100 &&
             data.status is string && data.status in ['active', 'inactive'] &&
             (!('description' in data) || data.description == null || (data.description is string && data.description.size() <= 500)) &&
             (!('phone' in data) || data.phone == null || (data.phone is string && data.phone.size() <= 50)) &&
             (!('whatsapp' in data) || data.whatsapp == null || (data.whatsapp is string && data.whatsapp.size() <= 50)) &&
             (!('email' in data) || data.email == null || (data.email is string && data.email.size() <= 100)) &&
             data.createdAt is string;
    }

    // User Role Validator
    function isValidUserRole(data) {
      return hasRequiredFields(data, ['email', 'role', 'status', 'createdAt']) &&
             hasOnlyAllowedFields(data, ['email', 'firstName', 'lastName', 'role', 'companyId', 'status', 'createdAt', 'updatedAt']) &&
             data.email is string && data.email.size() > 0 && data.email.size() <= 100 &&
             (!('firstName' in data) || data.firstName == null || (data.firstName is string && data.firstName.size() > 0 && data.firstName.size() <= 100)) &&
             (!('lastName' in data) || data.lastName == null || (data.lastName is string && data.lastName.size() > 0 && data.lastName.size() <= 100)) &&
             data.role is string && data.role in ['super_admin', 'company_admin', 'company_staff'] &&
             data.status is string && data.status in ['active', 'inactive'] &&
             data.createdAt is string &&
             (!('updatedAt' in data) || data.updatedAt == null || data.updatedAt is string) &&
             (
               (data.role == 'super_admin' && (!('companyId' in data) || data.companyId == null || data.companyId is string)) ||
               (
                 data.role in ['company_admin', 'company_staff'] &&
                 (
                   (data.status == 'active' && data.companyId is string && data.companyId.size() > 0 && data.companyId.size() <= 100) ||
                   (data.status == 'inactive' && (!('companyId' in data) || data.companyId == null || (data.companyId is string && data.companyId.size() <= 100)))
                 )
               )
             );
    }

    function isSelfPendingUserRoleCreate(roleEmail) {
      return isAuthenticated() &&
             request.auth.token.email is string &&
             request.auth.token.email == roleEmail &&
             request.resource.data.email == roleEmail &&
             request.resource.data.role == 'company_staff' &&
             request.resource.data.status == 'inactive' &&
             (!('companyId' in request.resource.data) || request.resource.data.companyId == null) &&
             isValidUserRole(request.resource.data);
    }

    // Client Error Log Validator
    function isValidClientErrorLog(data) {
      return hasRequiredFields(data, ['message', 'userEmail', 'createdAt']) &&
             hasOnlyAllowedFields(data, ['message', 'code', 'name', 'context', 'userEmail', 'userId', 'emailVerified', 'userAgent', 'url', 'createdAt']) &&
             data.message is string && data.message.size() > 0 && data.message.size() <= 1000 &&
             (!('code' in data) || data.code == null || (data.code is string && data.code.size() <= 100)) &&
             (!('name' in data) || data.name == null || (data.name is string && data.name.size() <= 100)) &&
             (!('context' in data) || data.context == null || data.context is map) &&
             data.userEmail == request.auth.token.email &&
             (!('userId' in data) || data.userId == null || data.userId == request.auth.uid) &&
             (!('emailVerified' in data) || data.emailVerified == null || data.emailVerified is bool) &&
             (!('userAgent' in data) || data.userAgent == null || (data.userAgent is string && data.userAgent.size() <= 500)) &&
             (!('url' in data) || data.url == null || (data.url is string && data.url.size() <= 500));
    }

    // ===============================================================
    // Rules for individual collections
    // ===============================================================

    match /products/{productId} {
      allow read: if true;
      allow create: if (isAdmin() && isValidProduct(request.resource.data)) ||
                       (isValidProduct(request.resource.data) && isCompanyMember(request.resource.data.companyId));
      allow update: if (isAdmin() && isValidProduct(request.resource.data)) ||
                       (isValidProduct(request.resource.data) &&
                        (
                          resource.data.companyId == request.resource.data.companyId ||
                          (!('companyId' in resource.data) && request.resource.data.companyId is string)
                        ) &&
                        isCompanyMember(request.resource.data.companyId)) ||
                       (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['stock']) && 
                        request.resource.data.stock is number && 
                        request.resource.data.stock >= 0 && 
                        request.resource.data.stock < resource.data.stock) ||
                       (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['stock', 'costPrice']) &&
                        request.resource.data.stock is number &&
                        request.resource.data.stock >= 0 &&
                        (!('costPrice' in request.resource.data) || request.resource.data.costPrice == null || request.resource.data.costPrice is number) &&
                        (
                          isAdmin() ||
                          isCompanyMember(resource.data.companyId) ||
                          isCompanyMember(request.resource.data.companyId)
                        ));
      allow delete: if isAdmin() || isCompanyMember(resource.data.companyId);
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if (isAdmin() || isCompanyMember(settingId)) && isValidSettings(request.resource.data);
    }

    match /customers/{customerId} {
      allow read: if isAdmin() || isCompanyMember(resource.data.companyId) || isOwnCustomerRecord(resource.data);
      allow create: if isValidCustomer(request.resource.data) &&
                    (
                      isAdmin() ||
                      isCompanyMember(request.resource.data.companyId) ||
                      (
                        isOwnCustomerRecord(request.resource.data) &&
                        isActiveCompany(request.resource.data.companyId) &&
                        request.resource.data.status == 'pending'
                      )
                    );
      allow update: if isValidCustomer(request.resource.data) &&
                    (
                      isAdmin() ||
                      isCompanyMember(resource.data.companyId) ||
                      isCompanyMember(request.resource.data.companyId) ||
                      (
                        isOwnCustomerRecord(resource.data) &&
                        isOwnCustomerRecord(request.resource.data) &&
                        request.resource.data.companyId == resource.data.companyId &&
                        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
                          'name',
                          'phone',
                          'address',
                          'logisticsLocationId',
                          'city',
                          'province',
                          'email',
                          'cedula',
                          'lastPurchase'
                        ])
                      )
                    );
      allow delete: if isAdmin() || isCompanyMember(resource.data.companyId);
    }

    match /orders/{orderId} {
      allow read: if isAdmin() || isCompanyMember(resource.data.companyId);
      allow create: if isValidOrder(request.resource.data) &&
                    (
                      isAdmin() ||
                      isCompanyMember(request.resource.data.companyId) ||
                      (
                        isActiveCompany(request.resource.data.companyId) &&
                        isOwnOrderCustomer(request.resource.data)
                      )
                    );
      allow update: if isAdmin() ||
                      (
                        isCompanyMember(resource.data.companyId) &&
                        isValidOrderWorkflowEdit()
                      ) ||
                      (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['items', 'stock']));
      allow delete: if isAdmin() || isCompanyMember(resource.data.companyId);
    }

    match /paymentTransactions/{transactionId} {
      allow read: if isAdmin() || isCompanyMember(resource.data.companyId);
      allow create, update: if (isAdmin() || isCompanyMember(request.resource.data.companyId)) && isValidTransaction(request.resource.data);
      allow delete: if isAdmin() || isCompanyMember(resource.data.companyId);
    }

    match /purchases/{purchaseId} {
      allow read: if isAdmin() || isCompanyMember(resource.data.companyId);
      allow create, update: if (isAdmin() || isCompanyMember(request.resource.data.companyId)) && isValidPurchase(request.resource.data);
      allow delete: if isAdmin() || isCompanyMember(resource.data.companyId);
    }

    match /logisticsLocations/{locationId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /shippingRates/{rateId} {
      allow read: if isAdmin() || isCompanyMember(resource.data.companyId);
      allow create, update: if (isAdmin() || isCompanyMember(request.resource.data.companyId)) &&
                            request.resource.data.companyId is string &&
                            request.resource.data.locationId is string &&
                            request.resource.data.locationLabel is string &&
                            request.resource.data.cost is number &&
                            request.resource.data.cost >= 0;
      allow delete: if isAdmin() || isCompanyMember(resource.data.companyId);
    }

    match /companies/{companyId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidCompany(request.resource.data);
      allow delete: if isAdmin();
    }

    match /userRoles/{roleEmail} {
      allow get: if isAdmin() ||
                   (
                     isAuthenticated() &&
                     request.auth.token.email is string &&
                     request.auth.token.email == roleEmail
                   );
      allow list: if isAdmin();
      allow create: if (
                      isAdmin() &&
                      request.resource.data.email == roleEmail &&
                      isValidUserRole(request.resource.data)
                    ) || isSelfPendingUserRoleCreate(roleEmail);
      allow update: if isAdmin() &&
                      request.resource.data.email == roleEmail &&
                      isValidUserRole(request.resource.data);
      allow delete: if isAdmin();
    }

    match /clientErrorLogs/{logId} {
      allow create: if isAuthenticated() && isValidClientErrorLog(request.resource.data);
      allow read, update, delete: if isAdmin();
    }
  }
}
